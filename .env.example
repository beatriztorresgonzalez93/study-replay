# Copia a .env.local (local) o pégalo en Vercel → Settings → Environment Variables
# Nombre exacto de la variable: MONGODB_URI
# NO uses la "Data API Key" de Atlas: usa Connect → Drivers → Node.js → cadena completa

# Atlas (incluye nombre de base /study-replay al final del host):
MONGODB_URI=mongodb+srv://USUARIO:CONTRASEÑA@cluster0.xxxxx.mongodb.net/study-replay?retryWrites=true&w=majority

# Local sin Atlas:
# MONGODB_URI=mongodb://127.0.0.1:27017/study-replay
